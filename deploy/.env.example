# Environment selector: dev | prod
ENVIRONMENT=dev

# Dev settings (Kind)
DEV_NAMESPACE=animestars-dev
DEV_CONTEXT=kind-animestars-dev
DEV_HOST_HEADER=animestars.local
DEV_KUBECONFIG=~/.kube/config

# Prod settings (k3s)
PROD_NAMESPACE=animestars-prod
PROD_CONTEXT=k3s
PROD_HOST_HEADER=ass.strawberrycat.dev
PROD_KUBECONFIG=~/.kube/config

# Prod SSH (for pushing images via tunnel to the private registry)
PROD_SSH_TARGET=user@server
