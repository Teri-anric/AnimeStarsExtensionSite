      "options": {
        "content": "## Container logs\nPromtail scrapes Docker; filter by **compose service**. When `LOG_JSON=true`, backend lines parse with `| json`. HTTP audit lines include `event=\"http_audit\"` (only if body logging is enabled).",
        "mode": "markdown"
      },
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 3 },
      "id": 301,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (compose_service) (rate({job=\"docker\"}[$__auto]))",
          "legendFormat": "{{compose_service}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log lines / s by Compose service",
      "type": "timeseries"
